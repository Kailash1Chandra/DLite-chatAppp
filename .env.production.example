# ============================================================================
# D-LITE - Production Environment Template
# ============================================================================
# Copy to `.env` on your server and fill real values.
# NEVER commit real secrets.
# ============================================================================

NODE_ENV=production

# Ports (published by docker-compose.yml)
CORE_PORT=4000
REALTIME_PORT=4003

# Public URLs used at frontend build-time (ensure these match your domains)
NEXT_PUBLIC_API_BASE_URL=https://api.your-domain.com
NEXT_PUBLIC_CHAT_SOCKET_URL=https://ws.your-domain.com
NEXT_PUBLIC_CALL_SOCKET_URL=https://ws.your-domain.com
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_ICE_SERVERS_JSON=[{"urls":["stun:stun.l.google.com:19302"]}]

# CORS / Socket.IO
CORS_ORIGINS=https://app.your-domain.com
SOCKET_IO_CORS_ORIGINS=https://app.your-domain.com

# Supabase (backend)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Auth fallback secret (recommended even if Supabase enabled)
AUTH_JWT_SECRET=

# Media (Cloudinary, optional)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=d-lite/media
MAX_FILE_SIZE_MB=50

# Worker backups (optional)
BACKUP_INTERVAL_SECONDS=300
BACKUP_BATCH_SIZE=500

# Uvicorn tuning
CORE_UVICORN_WORKERS=2
REALTIME_UVICORN_WORKERS=1
UVICORN_LOG_LEVEL=info

# realtime-service (Socket.IO + WebRTC signaling)

NODE_ENV=production
PORT=4003

# Socket.IO CORS (comma-separated or "*")
SOCKET_IO_CORS_ORIGINS=https://app.example.com

# Supabase (token validation / optional persistence)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Local auth fallback (recommended)
AUTH_JWT_SECRET=replace-with-strong-secret
JWT_SECRET=replace-with-strong-secret

# Optional: Uvicorn tuning
# UVICORN_WORKERS=1
# UVICORN_LOG_LEVEL=info


# frontend-service (Next.js)
#
# Vercel: Project → Settings → Environment Variables → add these, then redeploy.

NODE_ENV=production

# API endpoints (public)
NEXT_PUBLIC_API_BASE_URL=https://api.example.com
NEXT_PUBLIC_CHAT_SOCKET_URL=https://ws.example.com
NEXT_PUBLIC_CALL_SOCKET_URL=https://ws.example.com

# Supabase (public anon key only)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# WebRTC ICE servers (optional)
NEXT_PUBLIC_ICE_SERVERS_JSON=[{"urls":["stun:stun.l.google.com:19302"]}]

# Optional: MongoDB (used by Next.js API routes like /api/message-backup)
# MONGODB_URI=
# MONGODB_DB_NAME=d_lite_backup


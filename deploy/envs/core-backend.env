# core-backend (FastAPI REST) — generated template

NODE_ENV=production
PORT=4000

# CORS (comma-separated)
CORS_ORIGINS=https://app.example.com

# Supabase (get from Supabase project settings)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Local auth fallback secret (generated) — keep same across backend services
AUTH_JWT_SECRET=d-lite_auth_7wQm2pF8nK3rV6tZ1cX9aB4sY5uH0jL2
# (legacy alias supported)
JWT_SECRET=d-lite_auth_7wQm2pF8nK3rV6tZ1cX9aB4sY5uH0jL2

# Optional: Cloudinary media uploads
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
# CLOUDINARY_FOLDER=d-lite/media
# MAX_FILE_SIZE_MB=50

# Optional: force local auth mode
# AUTH_MODE=auto

# Optional: Uvicorn tuning
# UVICORN_WORKERS=2
# UVICORN_LOG_LEVEL=info


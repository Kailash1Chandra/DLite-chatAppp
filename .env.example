###############################################################################
# D-Lite (Supabase Auth) - minimal root env template
###############################################################################

# Frontend (public)
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
NEXT_PUBLIC_CHAT_SOCKET_URL=http://localhost:4003
NEXT_PUBLIC_CALL_SOCKET_URL=http://localhost:4003
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
# WebRTC: keep Google STUN and add your TURN server for mobile / different networks / symmetric NAT.
# Example (single line): STUN + TURN with long-term credentials:
# NEXT_PUBLIC_ICE_SERVERS_JSON=[{"urls":["stun:stun.l.google.com:19302"]},{"urls":["turn:YOUR_HOST:3478","turns:YOUR_HOST:5349"],"username":"turnuser","credential":"turnsecret"}]
NEXT_PUBLIC_ICE_SERVERS_JSON=[{"urls":["stun:stun.l.google.com:19302"]}]

# Backends (server-only)
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# core-backend
CORS_ORIGINS=http://localhost:3000

